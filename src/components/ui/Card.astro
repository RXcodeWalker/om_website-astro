---
interface Props {
  title: string;
  description: string;
  icon?: string;
  tags?: string[];
  date?: string;
  delay?: string;
  gradient?: string;
  class?: string;
}

const { title, description, icon, tags, date, delay = "0s", gradient, class: className = "" } = Astro.props;
---

<article 
  class={`glass-card glass-card-hover tilt-card reveal ${className}`} 
  style={`transition-delay: ${delay};`}
>
  <div class="card-shine"></div>
  
  {icon && (
    <div class="card-icon" style={gradient ? `background: ${gradient};` : ""}>
      <Fragment set:html={icon} />
    </div>
  )}

  <div class="card-content">
    <div class="card-header">
      <h3>{title}</h3>
      {date && <span class="card-date">{date}</span>}
    </div>
    <p class="text-muted">{description}</p>
    
    {tags && (
      <div class="tech-tags">
        {tags.map(tag => <span>{tag}</span>)}
      </div>
    )}
  </div>
</article>

<style>
  .glass-card {
    position: relative;
    padding: 2rem;
    border-radius: 24px;
    background: var(--glass-bg);
    backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .glass-card-hover:hover {
    transform: translateY(-6px) scale(1.01);
    box-shadow: var(--glass-shadow-hover);
    border-color: var(--accent-1);
  }

  .card-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    flex-shrink: 0;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .card-header h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
  }

  .card-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--accent-1);
    letter-spacing: 0.05em;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
  }

  .tech-tags span {
    padding: 0.3rem 0.8rem;
    border-radius: 50px;
    background: rgba(128, 128, 128, 0.1);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--muted-text);
  }

  .card-shine {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(255,255,255,0.14) 0%, transparent 60%);
    pointer-events: none;
    z-index: 10;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .glass-card:hover .card-shine { opacity: 1; }
</style>

<script is:inline>
  // Note: Tilt logic is handled by global script in BaseLayout or page
</script>