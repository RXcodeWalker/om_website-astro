---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import Card from '../components/ui/Card.astro';

const interests = [
  {
    title: "Football",
    description: "Die-hard Arsenal fan. I analyze tactics, follow transfers, and write about the beautiful game.",
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>',
    gradient: "linear-gradient(135deg, #FF4B2B, #FF416C)"
  },
  {
    title: "Coding",
    description: "Passionate about web development, software engineering, and learning new technologies.",
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>',
    gradient: "linear-gradient(135deg, #4cc9f0, #4361ee)"
  },
  {
    title: "Guitar",
    description: "LCM Grade 8, High Distinction. Currently working towards my Diploma. Rock music & live performance.",
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>',
    gradient: "linear-gradient(135deg, #7209b7, #b5179e)"
  },
  {
    title: "Growth",
    description: "Committed to continuous learning and personal development in all areas of life.",
    icon: '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>',
    gradient: "linear-gradient(135deg, #4ecdc4, #45b7af)"
  }
];
---

<BaseLayout title="Om — About">
  <main class="container main-content">
    
    <PageHeader 
      eyebrow="The Story" 
      title="About Me" 
      description="Hey! I'm Om Jhamvar — here's a bit about who I am and what drives me."
    />

    <section class="glass-card main-bio reveal">
      <div class="about-content">
        <p>Hey there! I'm Om Jhamvar, a 10th grade student with a passion for technology, football, and continuous learning. Welcome to my corner of the internet where I share my thoughts, projects, and journey.</p>
        <p>As a proud Arsenal supporter, I spend a lot of time analyzing matches, discussing tactics, and following the transfer market. Football isn't just a sport to me — it's a lens through which I explore strategy, teamwork, and resilience.</p>
        <p>On the tech side, I'm diving deep into web development and software engineering. I love building things that solve real problems and creating user experiences that feel magical.</p>
      </div>
    </section>

    <div class="section-label reveal">What Drives Me</div>
    <div class="interests-grid">
      {interests.map((interest, index) => (
        <Card 
          title={interest.title}
          description={interest.description}
          icon={interest.icon}
          gradient={interest.gradient}
          delay={`${index * 0.1}s`}
        />
      ))}
    </div>

    <section class="glass-card glass-feature reveal">
      <div class="feature-content">
        <h2>Let's Connect</h2>
        <p class="text-muted">I'm always excited to meet new people, discuss ideas, or collaborate on interesting projects.</p>
        <a href="/contact" class="btn-primary">Get in Touch</a>
      </div>
    </section>

  </main>

  <style>
    .main-bio {
      padding: 2.5rem;
      margin-bottom: 3rem;
    }
    .about-content p {
      margin-bottom: 1.5rem;
      line-height: 1.8;
      font-size: 1.1rem;
      color: var(--text-color);
    }
    .interests-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
      margin-bottom: 4rem;
    }
    .glass-feature {
      text-align: center;
      padding: 4rem 2rem;
      background: linear-gradient(135deg, rgba(76,201,240,0.05), rgba(138,79,255,0.05));
    }
    .feature-content h2 { margin-bottom: 1rem; }
    .feature-content p { margin-bottom: 2rem; max-width: 600px; margin-inline: auto; }
  </style>

  <script is:inline>
    // Universal 3D Tilt Script
    document.querySelectorAll('.tilt-card').forEach(card => {
      card.addEventListener('mousemove', e => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left, y = e.clientY - rect.top;
        const centerX = rect.width / 2, centerY = rect.height / 2;
        const rotateX = (y - centerY) / centerY * -8, rotateY = (x - centerX) / centerX * 8;
        card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateZ(10px)`;
        card.style.setProperty('--mouse-x', (x / rect.width * 100) + '%');
        card.style.setProperty('--mouse-y', (y / rect.height * 100) + '%');
      });
      card.addEventListener('mouseleave', () => card.style.transform = '');
    });
  </script>
</BaseLayout>