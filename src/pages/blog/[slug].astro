---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { extractKeyIdeas, extractStrikingLine } from '../../utils/postInsights';
import '../../styles/blog.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const allPosts = await getCollection('blog');
const post = allPosts.find(
  (p) => p.slug === slug || p.data.id === slug || p.data.id?.toString() === slug?.toString(),
);

const renderResult = post ? await post.render() : null;
const Content = renderResult ? renderResult.Content : null;
const postId = post ? post.data.id ?? post.slug : slug ?? '';
const postSlug = post?.slug ?? slug ?? '';
const postBody = post?.body ?? '';
const introIdeas = post ? extractKeyIdeas(postBody, 3) : [];
const introLine = post ? extractStrikingLine(postBody, post.data.excerpt) : '';
---

<BaseLayout title={post ? post.data.title : "Post Not Found"}>
  <div class="post-backdrop"></div>

  <a href="/blog" class="back-btn" style="font-family:var(--font-display);font-weight:600;">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="19" y1="12" x2="5" y2="12"></line>
      <polyline points="12 19 5 12 12 5"></polyline>
    </svg>
    Back to Blog
  </a>

  <div class="post-container" id="post-container">
    <article class="glass-card post-modal" id="post-content" data-post-id={postId} data-post-slug={postSlug}>
      {post && Content ? (
        <>
          <div class="post-header cinematic-intro" id="post-intro">
            <span class="category-badge intro-chip" data-intro-stage="chip">{post.data.category}</span>
            <h1 id="post-title" class="intro-title" data-intro-stage="title">{post.data.title}</h1>
            <p class="post-dek" data-intro-stage="dek">{post.data.excerpt}</p>
            <div class="blog-meta" id="post-meta" data-intro-stage="meta">
              <span class="blog-date">{post.data.date}</span>
              <span class="blog-reading-time">Calculating...</span>
              <span class="blog-views">Loading views...</span>
            </div>
            <figure class="post-hero-media" id="post-hero-media" data-intro-stage="hero" aria-label="Article hero panel">
              <div class="post-hero-glow" aria-hidden="true"></div>
              <figcaption class="post-hero-content">
                <p class="post-hero-kicker">Inside this article</p>
                <p class="post-hero-line">"{introLine}"</p>
                <ul class="post-hero-ideas">
                  {introIdeas.map((idea) => (
                    <li>{idea}</li>
                  ))}
                </ul>
              </figcaption>
            </figure>
          </div>
          <div class="post-body" id="post-body">
            <Content />
          </div>
        </>
      ) : (
        <div style="padding: 4rem; text-align: center;">
          <h1>Post Not Found</h1>
          <p>We couldn't find a post with slug: "{slug}"</p>
          <a href="/blog" class="read-more-btn" style="display: inline-block; margin-top: 2rem;">Return to Blog</a>
        </div>
      )}
    </article>
  </div>

  <aside class="post-sidebar glass-card" id="post-sidebar" aria-label="Post toolbar">
    <div class="sidebar-progress-wrap" title="Reading progress">
      <svg class="progress-ring" width="44" height="44" viewBox="0 0 44 44">
        <circle class="progress-ring-track" cx="22" cy="22" r="18"/>
        <circle class="progress-ring-fill" id="progress-ring-fill" cx="22" cy="22" r="18"/>
      </svg>
      <span class="progress-percent" id="progress-percent">0%</span>
    </div>
    <div class="sidebar-divider"></div>
    <button class="sidebar-btn like-btn" id="like-btn" aria-label="Like this post" title="Like this post">
      <span class="like-count" id="like-count"></span>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </button>
    <button class="sidebar-btn bookmark-btn" id="bookmark-btn" aria-label="Bookmark this post" title="Bookmark">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
      </svg>
    </button>
    <button class="sidebar-btn share-btn" id="share-btn" aria-label="Share this post" title="Share">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
      </svg>
    </button>
    <div class="sidebar-divider"></div>
    <button class="sidebar-btn" id="font-increase" title="Larger text"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/><line x1="19" y1="13" x2="22" y2="13"/><line x1="20.5" y1="11.5" x2="20.5" y2="14.5"/></svg></button>
    <button class="sidebar-btn" id="font-decrease" title="Smaller text"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/><line x1="19" y1="13" x2="22" y2="13"/></svg></button>
    <button class="sidebar-btn" id="line-spacing-btn" title="Line spacing"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/><polyline points="8 3 5 6 8 9"/><polyline points="16 15 19 18 16 21"/></svg></button>
    <div class="sidebar-divider"></div>
    <button class="sidebar-btn" id="toc-toggle-btn" title="Table of contents"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg></button>
    <button class="sidebar-btn" id="width-toggle" title="Wide mode"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg></button>
    <div class="sidebar-divider"></div>
    <button class="sidebar-btn" id="focus-mode-btn" title="Focus mode"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
    <button class="sidebar-btn" id="print-btn" title="Print"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg></button>
    <button class="sidebar-btn" id="copy-link-btn" title="Copy link"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg></button>
  </aside>

  <div class="toc-panel glass-card" id="toc-panel" aria-hidden="true">
    <div class="toc-header">
      <span>Contents</span>
      <button class="toc-close" id="toc-close" aria-label="Close">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <nav class="toc-nav" id="toc-nav">
      <p class="toc-empty">No sections found.</p>
    </nav>
    <div class="toc-footer-bar">
      <div class="toc-progress-fill" id="toc-progress-fill"></div>
    </div>
  </div>

  <div class="share-panel glass-card" id="share-panel" aria-hidden="true">
    <div class="share-panel-title">Share this post</div>
    <div class="share-actions">
      <button class="share-action-btn" id="share-copy">Copy link</button>
      <a class="share-action-btn" id="share-twitter" href="#" target="_blank">Twitter / X</a>
      <a class="share-action-btn" id="share-linkedin" href="#" target="_blank">LinkedIn</a>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script is:inline>
    window.supabaseClient = window.supabase.createClient(
      "https://ypvgtqhbltjzxiwprdfb.supabase.co",
      "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inlwdmd0cWhibHRqenhpd3ByZGZiIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE3NDY0NTUsImV4cCI6MjA4NzMyMjQ1NX0.F1lmv_4P6Q41ha3YOqI7yYj9IkbaZpNPbZPeGzAMK_I"
    );
  </script>

  <script is:inline src="/js/spectacular-shared.js"></script>
  <script is:inline src="/js/post.js"></script>
  <script is:inline src="/js/reader.js"></script>
  <script is:inline src="/js/summarizer.js"></script>
  <script is:inline src="/js/utils/cursor.js"></script>
</BaseLayout>
