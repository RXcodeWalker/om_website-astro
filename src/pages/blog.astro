---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import BlogSearch from '../components/blog/BlogSearch.astro';
import { estimateReadingMinutes, extractKeyIdeas, extractStrikingLine, formatReadingTime } from '../utils/postInsights';

const dateValue = (value: string) => {
  const parsed = Date.parse(value);
  return Number.isNaN(parsed) ? 0 : parsed;
};

const blogEntries = await getCollection('blog');
const allPosts = blogEntries
  .map((entry) => {
    const markdownBody = entry.body ?? '';
    const readingMinutes = estimateReadingMinutes(markdownBody);

    return {
      title: entry.data.title,
      date: entry.data.date,
      category: entry.data.category,
      excerpt: entry.data.excerpt,
      id: entry.data.id ?? entry.slug,
      slug: entry.slug,
      featured: entry.data.featured ?? false,
      readTime: formatReadingTime(readingMinutes),
      keyIdeas: extractKeyIdeas(markdownBody, 3),
      strikingLine: extractStrikingLine(markdownBody, entry.data.excerpt),
    };
  })
  .sort((a, b) => dateValue(b.date) - dateValue(a.date));

const featuredPost = allPosts.find((post) => post.featured) ?? allPosts[0];
const gridPosts = allPosts.filter((post) => post.id !== featuredPost?.id);
const categories = [...new Set(allPosts.map((post) => post.category))].sort((a, b) => a.localeCompare(b));
const postHref = (slug: string) => `/blog/${encodeURIComponent(slug)}`;
---

<BaseLayout title="Om's Blog" description="In-depth Arsenal analysis, tactical breakdowns, and football insights by Om Jhamvar.">
  <main class="container main-content blog-page">
    <PageHeader
      eyebrow="Words & Thoughts"
      title="My Blog"
      description="Tactical analysis of sports and posts about personal growth, unfiltered and straight from the source."
      useTypewriter={true}
    />

    <section class="newsletter-slot newsletter-slot-compact reveal" aria-label="Newsletter signup top">
      <p><strong>Get new posts by email.</strong> Weekly writing on projects, books, music, and sports analysis.</p>
      <a href="/contact" class="btn-primary">Subscribe</a>
    </section>

    <BlogSearch categories={categories} />

    <section class="blog-index-shell">
      {
        featuredPost && (
          <article class="featured-story glass-card glass-card-hover reveal" id="featured-story" data-featured-id={featuredPost.id}>
            <div class="featured-story-copy">
              <p class="featured-kicker">Lead Story</p>
              <div class="featured-story-meta">
                <span class="category-badge">{featuredPost.category}</span>
                <span class="featured-story-date">{featuredPost.date}</span>
              </div>
              <h2>{featuredPost.title}</h2>
              <p class="featured-story-excerpt">{featuredPost.excerpt}</p>

              {/* improvement #10: pull-quote from striking line */}
              {featuredPost.strikingLine && (
                <blockquote class="featured-pull-quote">{featuredPost.strikingLine}</blockquote>
              )}

              <div class="featured-story-footer">
                <a href={postHref(featuredPost.slug)} class="featured-read-more">
                  Read the full piece
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </a>
                <p class="featured-story-note">A strong place to start if you want the tone of the archive fast.</p>
              </div>
            </div>

            <div class="featured-story-side" aria-hidden="true">
              <div class="featured-story-orb"></div>
              <p class="featured-side-label">Editorial Pick</p>
              <p class="featured-side-copy">
                Selected as the lead read for this archive view. Expect a longer, sharper argument than the rest of the wall.
              </p>
              <div class="featured-side-stat">
                <span>Archive</span>
                <strong>{allPosts.length} stories</strong>
              </div>
            </div>
          </article>
        )
      }

      <div class="blog-grid-head reveal">
        <div>
          <p class="blog-grid-kicker">Archive Wall</p>
          <h2>Recent writing, notes, and match breakdowns.</h2>
        </div>
        <p class="blog-results-summary" id="results-summary">
          {gridPosts.length} supporting {gridPosts.length === 1 ? 'story' : 'stories'}
        </p>
      </div>

      {/* improvement #12: empty state (shown via JS when no results) */}
      <div class="blog-empty-state" id="blog-empty-state" aria-live="polite" hidden>
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          <line x1="8" y1="11" x2="14" y2="11"/>
        </svg>
        <p class="empty-state-msg">No posts match your search.</p>
        <button class="empty-state-clear" id="empty-clear-btn" type="button">Clear filters</button>
      </div>

      <div class="blog-grid" id="blog-grid">
        {
          gridPosts.map((post) => (
            /* improvements #11 (remove kicker, add data-category), #13 (stretched link), #7 (readTime) */
            <article class="glass-card glass-card-hover blog-card" data-post-id={post.id} data-category={post.category}>
              <h3><a href={postHref(post.slug)} class="blog-card-stretched-link">{post.title}</a></h3>

              <div class="blog-meta">
                <span class="category-badge">{post.category}</span>
                <span class="blog-date">{post.date}</span>
                <span class="reading-time">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                  </svg>
                  {post.readTime}
                </span>
              </div>

              <p class="blog-excerpt">{post.excerpt}</p>

              <a href={postHref(post.slug)} class="read-more-btn" tabindex="-1" aria-hidden="true">
                Read More
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </article>
          ))
        }
      </div>

      <section id="newsletter-signup" class="newsletter-slot newsletter-slot-strong reveal" aria-label="Newsletter signup bottom">
        <div>
          <p class="newsletter-kicker">Newsletter</p>
          <h3>Build with me in public</h3>
          <p>
            I send focused updates on what I am building, what I am reading, and how I improve execution each week.
          </p>
        </div>
        <div class="newsletter-cta-group">
          <a href="/contact" class="btn-primary">Subscribe for updates</a>
          <a href="/" class="btn-ghost">Back to home</a>
        </div>
      </section>
    </section>
  </main>

  <style>
    /* improvement #10: featured pull-quote */
    .featured-pull-quote {
      margin: 1rem 0 1.25rem;
      padding: 0.85rem 1rem 0.85rem 1.1rem;
      border-left: 3px solid var(--accent-1);
      background: color-mix(in srgb, var(--accent-1) 6%, transparent);
      border-radius: 0 10px 10px 0;
      font-style: italic;
      font-size: 0.96rem;
      line-height: 1.62;
      color: var(--muted-text);
    }

    /* improvement #12: empty state */
    .blog-empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      padding: 3.5rem 1rem;
      color: var(--muted-text);
      text-align: center;
    }
    .blog-empty-state svg {
      opacity: 0.35;
    }
    .empty-state-msg {
      font-size: 1rem;
      font-weight: 500;
      color: var(--text-color);
      margin: 0;
    }
    .empty-state-clear {
      padding: 0.55rem 1.25rem;
      border-radius: 100px;
      border: 1px solid var(--glass-border);
      background: var(--glass-bg);
      color: var(--accent-1);
      font-family: var(--font-body);
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.22s ease;
    }
    .empty-state-clear:hover {
      background: color-mix(in srgb, var(--accent-1) 10%, transparent);
      border-color: var(--accent-1);
    }

    /* improvement #13: stretched link & card clickability */
    .blog-page .blog-card {
      position: relative;
      cursor: pointer;
    }
    .blog-card-stretched-link {
      color: inherit;
      text-decoration: none;
    }
    .blog-card-stretched-link::after {
      content: '';
      position: absolute;
      inset: 0;
      z-index: 0;
      border-radius: var(--card-radius, 20px);
    }
    .blog-card h3,
    .blog-card .blog-meta,
    .blog-card .blog-excerpt,
    .blog-card .reading-time,
    .blog-card .blog-date,
    .blog-card .category-badge {
      position: relative;
      z-index: 1;
    }
    .blog-card .read-more-btn {
      position: relative;
      z-index: 2;
    }

    .newsletter-slot {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      border-radius: var(--card-radius);
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      box-shadow: var(--glass-shadow);
    }
    .newsletter-slot p {
      margin: 0;
      color: var(--muted-text);
      line-height: 1.6;
    }
    .newsletter-slot-compact {
      margin: 0 0 1.5rem;
      padding: 1rem 1.25rem;
    }
    .newsletter-slot-strong {
      margin-top: 2rem;
      padding: 1.4rem;
    }
    .newsletter-kicker {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent-1);
      margin-bottom: 0.5rem;
    }
    .newsletter-slot-strong h3 {
      margin: 0 0 0.5rem;
      font-size: 1.35rem;
      font-family: var(--font-display);
    }
    .newsletter-cta-group {
      display: flex;
      gap: 0.65rem;
      align-items: center;
      flex-wrap: wrap;
      flex-shrink: 0;
    }
    @media (max-width: 768px) {
      .newsletter-slot {
        flex-direction: column;
        align-items: flex-start;
      }
      .newsletter-slot-compact,
      .newsletter-slot-strong {
        padding: 1rem;
      }
    }
  </style>

  <script is:inline define:vars={{ allPosts }}>
    window.allPosts = allPosts;
  </script>
  <script is:inline>
    // improvement #12: empty state toggle + clear button
    (() => {
      const emptyState = document.getElementById('blog-empty-state');
      const grid = document.getElementById('blog-grid');
      const clearBtn = document.getElementById('empty-clear-btn');
      if (!emptyState || !grid) return;

      function checkEmpty() {
        const visible = grid.querySelectorAll('.blog-card:not(.hidden)').length;
        emptyState.hidden = visible > 0;
      }

      // Watch for class changes on grid children
      const mo = new MutationObserver(checkEmpty);
      mo.observe(grid, { subtree: true, attributes: true, attributeFilter: ['class'] });

      if (clearBtn) {
        clearBtn.addEventListener('click', () => {
          // Reset active filter to "all"
          const allBtn = document.querySelector('.filter-btn[data-filter="all"]');
          if (allBtn) allBtn.click();
          // Clear search
          const searchInput = document.getElementById('search-input');
          if (searchInput) { searchInput.value = ''; searchInput.dispatchEvent(new Event('input')); }
        });
      }
    })();
  </script>
  <script is:inline src="/js/spectacular-shared.js"></script>
  <script is:inline src="/js/blog.js"></script>
  <script is:inline src="/js/utils/cursor.js"></script>
</BaseLayout>
