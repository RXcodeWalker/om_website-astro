---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Stats from '../components/Stats.astro';
import Skills from '../components/Skills.astro';
import AboutStrip from '../components/AboutStrip.astro';
import WelcomeCTA from '../components/WelcomeCTA.astro';
---

<BaseLayout title="Om — Home">
  
  <Hero />
  <Marquee />

  <main class="container main-content" style="padding-top: 0rem;">
    
    <!-- LATEST BLOG DROPS -->
    <section class="section reveal" style="margin:1rem; padding:1rem; align-content: center;">
      <div class="section-label">Fresh Off The Press</div>
      <h2 class="section-heading"><span>Latest drops</span></h2>

      <div class="featured-grid" >
        <div class="feature-card tilt-card" id="latest-post-card">
          <div class="card-shine"></div>
          <div class="feature-card-accent"></div>
          <div class="feature-card-tag">Latest Post</div>
          <div id="latest-post-inner">
            <h3>Loading...</h3>
          </div>
        </div>
      </div>
    </section>

    <Stats />
    <Skills />
    <AboutStrip />
    <WelcomeCTA />

  </main>

  <style>
    /* Page specific layout */
    .featured-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    @media (max-width: 640px) {
      .featured-grid { grid-template-columns: 1fr; }
    }

    .feature-card {
      position: relative;
      padding: 2rem;
      border-radius: 24px;
      background: var(--glass-bg);
      backdrop-filter: blur(20px) saturate(180%);
      border: 1px solid var(--glass-border);
      box-shadow: var(--glass-shadow);
      overflow: hidden;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      text-decoration: none;
      color: var(--text-color);
      display: block;
    }
    .feature-card:hover {
      transform: translateY(-6px) scale(1.01);
      box-shadow: var(--glass-shadow-hover);
      border-color: var(--accent-1);
    }
    .feature-card-accent {
      position: absolute;
      top: 0; right: 0;
      width: 120px; height: 120px;
      border-radius: 50%;
      filter: blur(50px);
      opacity: 0.2;
      background: var(--accent-1);
      transition: all 0.4s ease;
    }
    .feature-card:hover .feature-card-accent {
      opacity: 0.4;
      transform: scale(1.3);
    }
    .feature-card-tag {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent-1);
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .feature-card-tag::before {
      content: '';
      width: 20px;
      height: 1px;
      background: var(--accent-1);
    }
    .feature-card h3 {
      font-family: var(--font-display);
      font-size: 1.3rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
      color: var(--text-color);
    }
    .feature-card-arrow {
      margin-top: 1.5rem;
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--font-display);
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--accent-1);
      transition: gap 0.3s ease;
    }
    .feature-card:hover .feature-card-arrow { gap: 0.8rem; }

    @media (max-width: 768px) {
      .main-content { padding-top: 1rem !important; padding-bottom: 2rem !important; }
      .section { margin-bottom: 2.5rem !important; margin-top: 1.5rem !important; }
      .section-heading { margin-bottom: 1.25rem !important; font-size: 2.2rem !important; }
      .featured-grid { gap: 1rem !important; }
    }
  </style>

  <script is:inline>
    // 3D TILT CARDS & BLOG FETCH
    (() => {
      'use strict';

      // Load latest blog post
      fetch("/data/blog.json")
        .then(res => res.json())
        .then(posts => {
          const post = posts[0];
          if (!post) return;
          const inner = document.getElementById('latest-post-inner');
          if (inner) {
            inner.innerHTML = `
              <h3 style="font-family:var(--font-display);font-weight:700;font-size:1.3rem;margin-bottom:0.75rem;">${post.title}</h3>
              <div class="blog-meta">
                <span class="category-badge">${post.category}</span>
                <span class="blog-date">${post.date}</span>
              </div>
              <p class="text-muted" style="font-size:0.9rem;line-height:1.6;margin-bottom:1.5rem;">${post.excerpt}</p>
              <a href="/blog-post?id=${post.id}" class="feature-card-arrow">
                Read post
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            `;
          }
        });

      // 3D TILT CARDS
      document.querySelectorAll('.tilt-card').forEach(card => {
        card.addEventListener('mousemove', e => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left, y = e.clientY - rect.top;
          const centerX = rect.width / 2, centerY = rect.height / 2;
          const rotateX = (y - centerY) / centerY * -8, rotateY = (x - centerX) / centerX * 8;
          card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateZ(10px)`;
          card.style.setProperty('--mouse-x', (x / rect.width * 100) + '%');
          card.style.setProperty('--mouse-y', (y / rect.height * 100) + '%');
        });
        card.addEventListener('mouseleave', () => card.style.transform = '');
      });
    })();
  </script>
</BaseLayout>